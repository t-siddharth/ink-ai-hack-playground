# Recognition API URL (for handwriting recognition)
INK_RECOGNITION_API_URL=

# OpenRouter API key (for LLM inference)
# Get your key at https://openrouter.ai/keys — use the secret that starts with sk-or-v1-
# No quotes, no spaces around =, no "Bearer " prefix (we trim those if pasted).
INK_OPENROUTER_API_KEY=
# Or use the name from OpenRouter’s own docs (either works; don’t set both to different values):
# OPENROUTER_API_KEY=
# Optional model id (default: google/gemini-2.5-flash). See https://openrouter.ai/models
# INK_OPENROUTER_MODEL=openai/gpt-4o-mini
# Optional: set these for OpenRouter leaderboard attribution
# INK_OPENROUTER_SITE_URL=https://your-site.com
# INK_OPENROUTER_SITE_NAME=Ink Playground

# fal.ai API key (for AI sketch image generation)
# Get your key at https://fal.ai/dashboard/keys
INK_FAL_AI_API_KEY=

# Gemini API key (for AI image generation)
# Get your key at https://aistudio.google.com/apikey
INK_GEMINI_API_KEY=
